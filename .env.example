KEYHUB_ENV=development
KEYHUB_HTTP_ADDR=:8080
KEYHUB_DATABASE_DSN=keyhub:keyhub@tcp(mysql:3306)/keyhub?parseTime=true&loc=Local&charset=utf8mb4,utf8
KEYHUB_AUTO_MIGRATE=true
KEYHUB_MIGRATIONS_DIR=migrations
KEYHUB_STATIC_DIR=web/dist
KEYHUB_NEWAPI_BASE_URL=http://new-api:3000
KEYHUB_NEWAPI_ADMIN_TOKEN=
KEYHUB_NEWAPI_ADMIN_USER_ID=1
KEYHUB_NEWAPI_QUOTA_PER_USD=500000
KEYHUB_AGGREGATION_TARGETS_JSON=[{"code":"default","name":"默认聚合平台","baseUrl":"http://new-api:3000","token":"replace-with-keyhub-push-token"}]
KEYHUB_ENCRYPTION_KEY=replace-with-32-byte-base64-key
KEYHUB_AUTH_ENABLED=true
KEYHUB_REGISTRATION_ENABLED=true
KEYHUB_BOOTSTRAP_ADMIN_USER=admin
KEYHUB_BOOTSTRAP_ADMIN_PASSWORD=change-me-now
KEYHUB_SESSION_TTL=24h
KEYHUB_COOKIE_SECURE=false
KEYHUB_WORKER_ENABLED=false
KEYHUB_POOL_REFILL_INTERVAL=10m
KEYHUB_HEALTH_CHECK_INTERVAL=30m
KEYHUB_USAGE_SYNC_INTERVAL=15m
